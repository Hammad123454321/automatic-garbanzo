generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum BusinessMode {
  RETAIL
  RESTAURANT
  BEAUTY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  READY
  COMPLETED
  CANCELLED
  REFUNDED
}

enum OrderType {
  COUNTER
  DINE_IN
  TAKEOUT
  DELIVERY
  ONLINE
  QR_TABLE
  KIOSK
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  VOIDED
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  APPLE_PAY
  GOOGLE_PAY
  QR_VENMO
  QR_ZELLE
  GIFT_CARD
  MEMBERSHIP_BALANCE
  SPLIT
}

enum CardBrand {
  VISA
  MASTERCARD
  AMEX
  DISCOVER
  OTHER
}

enum ProductType {
  STANDARD
  WEIGHTED
  TIME_BASED
  PRICE_ON_DEMAND
  SERVICE
}

enum WeightUnit {
  KG
  LB
  OZ
  G
}

enum TimeUnit {
  MINUTE
  HOUR
}

enum InventoryAction {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  DAMAGE
  EXPIRY
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PrinterConnection {
  USB
  NETWORK
}

enum PrinterPurpose {
  RECEIPT
  KITCHEN
  BAR
  LABEL
  ALL
}

enum CommissionType {
  FIXED
  PERCENTAGE
}

enum GiftCardStatus {
  ACTIVE
  DEPLETED
  SUSPENDED
}

enum DeliveryProvider {
  SELF
  DOORDASH
  UBER_EATS
}

enum SyncStatus {
  PENDING
  SYNCED
  CONFLICT
  FAILED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  VOID
  REFUND
  DISCOUNT
  PRICE_OVERRIDE
  PAYMENT
}

// ─────────────────────────────────────────────
// SUPER ADMIN / PLATFORM
// ─────────────────────────────────────────────

model SuperAdmin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Merchant {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  phone         String?
  address       String?
  logoUrl       String?
  isActive      Boolean   @default(true)
  maxStores     Int       @default(1)
  maxDevices    Int       @default(3)
  billingPlan   String    @default("basic")
  baseFee       Decimal   @default(0) @db.Decimal(10, 2)
  perStoreFee   Decimal   @default(0) @db.Decimal(10, 2)
  perDeviceFee  Decimal   @default(0) @db.Decimal(10, 2)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  stores        Store[]
  staff         Staff[]
  customers     Customer[]
  giftCards     GiftCard[]
  featureFlags  MerchantFeatureFlag[]
  billingEvents BillingEvent[]
}

model MerchantFeatureFlag {
  id         String   @id @default(uuid())
  merchantId String
  featureKey String
  enabled    Boolean  @default(false)
  storeId    String?
  updatedAt  DateTime @updatedAt

  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, featureKey, storeId])
}

model BillingEvent {
  id          String   @id @default(uuid())
  merchantId  String
  description String
  amount      Decimal  @db.Decimal(10, 2)
  type        String
  metadata    Json?
  createdAt   DateTime @default(now())

  merchant    Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// STORES & DEVICES
// ─────────────────────────────────────────────

model Store {
  id              String       @id @default(uuid())
  merchantId      String
  name            String
  businessMode    BusinessMode @default(RETAIL)
  email           String?
  phone           String?
  address         String?
  city            String?
  state           String?
  zipCode         String?
  country         String       @default("US")
  logoUrl         String?
  timezone        String       @default("America/New_York")
  currency        String       @default("USD")
  taxRate         Decimal      @default(0) @db.Decimal(5, 4)
  taxName         String       @default("Tax")
  businessHours   Json?
  onlineHours     Json?
  isActive        Boolean      @default(true)
  onlineEnabled   Boolean      @default(false)
  onlinePaused    Boolean      @default(false)
  onlinePauseUntil DateTime?
  pickupEnabled   Boolean      @default(true)
  deliveryEnabled Boolean      @default(false)
  pickupPrepTime  Int          @default(15)
  deliveryPrepTime Int         @default(30)
  deliveryRadius  Decimal?     @db.Decimal(5, 2)
  deliveryFee     Decimal?     @db.Decimal(10, 2)
  minOrderAmount  Decimal?     @db.Decimal(10, 2)
  receiptFooter   String?
  receiptHeader   String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  merchant        Merchant     @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  devices         Device[]
  printers        Printer[]
  staff           StaffStore[]
  categories      Category[]
  products        Product[]
  menuItems       MenuItem[]
  orders          Order[]
  tables          RestaurantTable[]
  reservations    Reservation[]
  inventory       Inventory[]
  customers       StoreCustomer[]
  timeClock       TimeEntry[]
  reports         Report[]
  syncQueue       SyncQueue[]
  auditLogs       AuditLog[]
}

model Device {
  id             String   @id @default(uuid())
  storeId        String
  name           String
  terminalId     String?
  serialNumber   String?
  ipAddress      String?
  port           Int?
  merchantId     String?
  terminalKey    String?
  isActive       Boolean  @default(true)
  isOnline       Boolean  @default(false)
  lastSeen       DateTime?
  config         Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders         Order[]

  @@unique([storeId, terminalId])
}

model Printer {
  id           String            @id @default(uuid())
  storeId      String
  name         String
  connection   PrinterConnection @default(NETWORK)
  ipAddress    String?
  port         Int               @default(9100)
  usbPort      String?
  purpose      PrinterPurpose    @default(ALL)
  paperWidth   Int               @default(80)
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  store        Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  routingRules PrinterRoute[]
}

model PrinterRoute {
  id         String  @id @default(uuid())
  printerId  String
  categoryId String?
  productId  String?

  printer    Printer  @relation(fields: [printerId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// STAFF & PERMISSIONS
// ─────────────────────────────────────────────

model Role {
  id          String       @id @default(uuid())
  merchantId  String
  name        String
  description String?
  isDefault   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  staffRoles       StaffRole[]
  rolePermissions  RolePermission[]

  @@unique([merchantId, name])
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  name        String
  description String?
  module      String

  rolePermissions RolePermission[]
  staffPermissions StaffPermission[]
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  granted      Boolean    @default(true)

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Staff {
  id          String    @id @default(uuid())
  merchantId  String
  firstName   String
  lastName    String
  email       String?
  phone       String?
  username    String
  password    String
  pin         String?
  avatarUrl   String?
  isActive    Boolean   @default(true)
  hourlyWage  Decimal?  @db.Decimal(10, 2)
  hireDate    DateTime?
  language    String    @default("en")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  merchant         Merchant          @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  stores           StaffStore[]
  roles            StaffRole[]
  permissions      StaffPermission[]
  orders           Order[]
  timeEntries      TimeEntry[]
  tips             OrderTip[]
  commissions      Commission[]
  auditLogs        AuditLog[]
  appointmentServices AppointmentService[] @relation("ServiceStaff")
  schedules        StaffSchedule[]

  @@unique([merchantId, username])
}

model StaffStore {
  staffId  String
  storeId  String
  isPrimary Boolean @default(false)

  staff    Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  store    Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([staffId, storeId])
}

model StaffRole {
  staffId String
  roleId  String

  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  role    Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([staffId, roleId])
}

model StaffPermission {
  id           String     @id @default(uuid())
  staffId      String
  permissionId String
  granted      Boolean    @default(true)

  staff        Staff      @relation(fields: [staffId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([staffId, permissionId])
}

model TimeEntry {
  id         String    @id @default(uuid())
  staffId    String
  storeId    String
  clockIn    DateTime  @default(now())
  clockOut   DateTime?
  breakMinutes Int     @default(0)
  hoursWorked Decimal? @db.Decimal(8, 2)
  wageRate   Decimal?  @db.Decimal(10, 2)
  totalPay   Decimal?  @db.Decimal(10, 2)
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  staff      Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)
  store      Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model StaffSchedule {
  id          String   @id @default(uuid())
  staffId     String
  storeId     String
  dayOfWeek   Int
  startTime   String
  endTime     String
  isRecurring Boolean  @default(true)
  specificDate DateTime?
  createdAt   DateTime @default(now())

  staff       Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// CATALOG — PRODUCTS, CATEGORIES, MODIFIERS
// ─────────────────────────────────────────────

model Category {
  id          String    @id @default(uuid())
  storeId     String
  name        String
  nameZh      String?
  description String?
  imageUrl    String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  printerId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products    Product[]
  menuItems   MenuItem[]
  modifierGroups CategoryModifierGroup[]
}

model ModifierGroup {
  id           String    @id @default(uuid())
  storeId      String
  name         String
  nameZh       String?
  required     Boolean   @default(false)
  minSelect    Int       @default(0)
  maxSelect    Int       @default(1)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  options      ModifierOption[]
  productGroups ProductModifierGroup[]
  categoryGroups CategoryModifierGroup[]
  menuItemGroups MenuItemModifierGroup[]
}

model ModifierOption {
  id              String        @id @default(uuid())
  modifierGroupId String
  name            String
  nameZh          String?
  priceAdjustment Decimal       @default(0) @db.Decimal(10, 2)
  isDefault       Boolean       @default(false)
  isActive        Boolean       @default(true)
  printerId       String?
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())

  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  orderItemModifiers OrderItemModifier[]
}

model ProductModifierGroup {
  productId       String
  modifierGroupId String
  sortOrder       Int    @default(0)

  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@id([productId, modifierGroupId])
}

model CategoryModifierGroup {
  categoryId      String
  modifierGroupId String
  sortOrder       Int    @default(0)

  category        Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@id([categoryId, modifierGroupId])
}

model Product {
  id               String       @id @default(uuid())
  storeId          String
  categoryId       String?
  sku              String?
  barcode          String?
  name             String
  nameZh           String?
  description      String?
  imageUrl         String?
  type             ProductType  @default(STANDARD)
  price            Decimal      @default(0) @db.Decimal(10, 2)
  costPrice        Decimal?     @db.Decimal(10, 2)
  taxRate          Decimal?     @db.Decimal(5, 4)
  isTaxInclusive   Boolean      @default(false)
  weightUnit       WeightUnit?
  timeUnit         TimeUnit?
  expirationDate   DateTime?
  isActive         Boolean      @default(true)
  trackInventory   Boolean      @default(true)
  lowStockAlert    Int          @default(5)
  printerId        String?
  sortOrder        Int          @default(0)
  tags             String[]
  aiDescription    String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  store            Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category         Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  variants         ProductVariant[]
  modifierGroups   ProductModifierGroup[]
  inventory        Inventory[]
  orderItems       OrderItem[]
}

model ProductVariant {
  id          String   @id @default(uuid())
  productId   String
  name        String
  sku         String?
  barcode     String?
  price       Decimal  @db.Decimal(10, 2)
  costPrice   Decimal? @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory   Inventory[]
}

// Restaurant-specific menu items
model MenuItem {
  id               String    @id @default(uuid())
  storeId          String
  categoryId       String?
  name             String
  nameZh           String?
  description      String?
  imageUrl         String?
  price            Decimal   @db.Decimal(10, 2)
  taxRate          Decimal?  @db.Decimal(5, 4)
  isActive         Boolean   @default(true)
  isAvailable      Boolean   @default(true)
  availableFrom    DateTime?
  availableTo      DateTime?
  printerId        String?
  sortOrder        Int       @default(0)
  tags             String[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  store            Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category         Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  modifierGroups   MenuItemModifierGroup[]
  orderItems       OrderItem[]
}

model MenuItemModifierGroup {
  menuItemId      String
  modifierGroupId String
  sortOrder       Int    @default(0)

  menuItem        MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@id([menuItemId, modifierGroupId])
}

// Salon services
model Service {
  id             String   @id @default(uuid())
  storeId        String
  categoryId     String?
  name           String
  nameZh         String?
  description    String?
  price          Decimal  @db.Decimal(10, 2)
  duration       Int      @default(60)
  isActive       Boolean  @default(true)
  commissionType CommissionType?
  commissionRate Decimal? @db.Decimal(10, 2)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  appointments   AppointmentService[]
  orderItems     OrderItem[]
}

// ─────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────

model Order {
  id             String      @id @default(uuid())
  storeId        String
  deviceId       String?
  staffId        String?
  customerId     String?
  orderNumber    String
  type           OrderType   @default(COUNTER)
  status         OrderStatus @default(PENDING)
  tableId        String?
  tableNumber    String?
  partySize      Int?
  notes          String?
  subtotal       Decimal     @db.Decimal(10, 2)
  taxAmount      Decimal     @db.Decimal(10, 2)
  discountAmount Decimal     @default(0) @db.Decimal(10, 2)
  tipAmount      Decimal     @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal     @db.Decimal(10, 2)
  paidAmount     Decimal     @default(0) @db.Decimal(10, 2)
  changeAmount   Decimal     @default(0) @db.Decimal(10, 2)
  discountNote   String?
  isHeld         Boolean     @default(false)
  deliveryAddress Json?
  deliveryProvider DeliveryProvider?
  trackingCode   String?
  estimatedReady DateTime?
  completedAt    DateTime?
  refundedAt     DateTime?
  syncStatus     SyncStatus  @default(SYNCED)
  metadata       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  store          Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  device         Device?     @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  staff          Staff?      @relation(fields: [staffId], references: [id], onDelete: SetNull)
  customer       Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  table          RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
  items          OrderItem[]
  payments       Payment[]
  tips           OrderTip[]
  discounts      OrderDiscount[]
  splits         OrderSplit[]

  @@unique([storeId, orderNumber])
}

model OrderItem {
  id              String    @id @default(uuid())
  orderId         String
  productId       String?
  menuItemId      String?
  serviceId       String?
  name            String
  nameZh          String?
  quantity        Decimal   @db.Decimal(10, 4)
  unitPrice       Decimal   @db.Decimal(10, 2)
  modifierTotal   Decimal   @default(0) @db.Decimal(10, 2)
  discountAmount  Decimal   @default(0) @db.Decimal(10, 2)
  taxAmount       Decimal   @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal   @db.Decimal(10, 2)
  notes           String?
  printerId       String?
  status          String    @default("pending")
  staffId         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  menuItem        MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  service         Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  modifiers       OrderItemModifier[]
}

model OrderItemModifier {
  id               String         @id @default(uuid())
  orderItemId      String
  modifierOptionId String
  name             String
  priceAdjustment  Decimal        @db.Decimal(10, 2)

  orderItem        OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifierOption   ModifierOption @relation(fields: [modifierOptionId], references: [id], onDelete: Cascade)
}

model OrderDiscount {
  id          String   @id @default(uuid())
  orderId     String
  name        String
  type        String
  value       Decimal  @db.Decimal(10, 2)
  amount      Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderTip {
  id         String   @id @default(uuid())
  orderId    String
  staffId    String?
  amount     Decimal  @db.Decimal(10, 2)
  method     String?
  isPaid     Boolean  @default(false)
  paidAt     DateTime?
  createdAt  DateTime @default(now())

  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  staff      Staff?   @relation(fields: [staffId], references: [id], onDelete: SetNull)
}

model OrderSplit {
  id       String  @id @default(uuid())
  orderId  String
  label    String
  amount   Decimal @db.Decimal(10, 2)
  isPaid   Boolean @default(false)

  order    Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────

model Payment {
  id              String        @id @default(uuid())
  orderId         String
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  amount          Decimal       @db.Decimal(10, 2)
  tipAmount       Decimal       @default(0) @db.Decimal(10, 2)
  refundedAmount  Decimal       @default(0) @db.Decimal(10, 2)
  cardBrand       CardBrand?
  cardLast4       String?
  cardHolderName  String?
  authCode        String?
  transactionId   String?
  terminalResponse Json?
  giftCardId      String?
  giftCardLast4   String?
  referenceNumber String?
  notes           String?
  processedAt     DateTime?
  refundedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refunds         Refund[]
}

model Refund {
  id          String   @id @default(uuid())
  paymentId   String
  amount      Decimal  @db.Decimal(10, 2)
  reason      String?
  staffId     String?
  processedAt DateTime @default(now())
  metadata    Json?

  payment     Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// CUSTOMERS & MEMBERSHIP
// ─────────────────────────────────────────────

model Customer {
  id            String    @id @default(uuid())
  merchantId    String
  firstName     String
  lastName      String?
  email         String?
  phone         String?
  dateOfBirth   DateTime?
  gender        String?
  notes         String?
  loyaltyPoints Int       @default(0)
  memberBalance Decimal   @default(0) @db.Decimal(10, 2)
  memberLevel   String?
  isActive      Boolean   @default(true)
  language      String    @default("en")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  merchant      Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  stores        StoreCustomer[]
  orders        Order[]
  giftCards     CustomerGiftCard[]
  loyaltyEvents LoyaltyEvent[]
  appointments  Appointment[]
}

model StoreCustomer {
  customerId String
  storeId    String
  visitCount Int      @default(0)
  lastVisit  DateTime?

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([customerId, storeId])
}

model LoyaltyEvent {
  id          String   @id @default(uuid())
  customerId  String
  storeId     String
  orderId     String?
  points      Int
  type        String
  description String?
  createdAt   DateTime @default(now())

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model GiftCard {
  id            String        @id @default(uuid())
  merchantId    String
  code          String        @unique
  last4         String
  initialBalance Decimal      @db.Decimal(10, 2)
  currentBalance Decimal      @db.Decimal(10, 2)
  status        GiftCardStatus @default(ACTIVE)
  isPhysical    Boolean       @default(true)
  expiresAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  merchant      Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  customers     CustomerGiftCard[]
  transactions  GiftCardTransaction[]
}

model CustomerGiftCard {
  customerId  String
  giftCardId  String

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  giftCard    GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)

  @@id([customerId, giftCardId])
}

model GiftCardTransaction {
  id         String   @id @default(uuid())
  giftCardId String
  storeId    String
  orderId    String?
  type       String
  amount     Decimal  @db.Decimal(10, 2)
  balance    Decimal  @db.Decimal(10, 2)
  notes      String?
  createdAt  DateTime @default(now())

  giftCard   GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// INVENTORY
// ─────────────────────────────────────────────

model Inventory {
  id               String    @id @default(uuid())
  storeId          String
  productId        String?
  variantId        String?
  quantity         Decimal   @default(0) @db.Decimal(12, 4)
  reservedQuantity Decimal   @default(0) @db.Decimal(12, 4)
  updatedAt        DateTime  @updatedAt

  store            Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product          Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant          ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  transactions     InventoryTransaction[]

  @@unique([storeId, productId, variantId])
}

model InventoryTransaction {
  id          String          @id @default(uuid())
  inventoryId String
  action      InventoryAction
  quantity    Decimal         @db.Decimal(12, 4)
  balanceBefore Decimal       @db.Decimal(12, 4)
  balanceAfter  Decimal       @db.Decimal(12, 4)
  unitCost    Decimal?        @db.Decimal(10, 2)
  toStoreId   String?
  notes       String?
  referenceId String?
  staffId     String?
  supplierId  String?
  createdAt   DateTime        @default(now())

  inventory   Inventory       @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
}

model Supplier {
  id            String    @id @default(uuid())
  merchantId    String
  name          String
  contactName   String?
  email         String?
  phone         String?
  address       String?
  notes         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  purchaseOrders PurchaseOrder[]
}

model PurchaseOrder {
  id           String    @id @default(uuid())
  storeId      String
  supplierId   String?
  orderNumber  String
  status       String    @default("draft")
  totalAmount  Decimal   @db.Decimal(10, 2)
  notes        String?
  orderedAt    DateTime?
  receivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  supplier     Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  items        PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  productId       String?
  name            String
  quantity        Decimal       @db.Decimal(12, 4)
  unitCost        Decimal       @db.Decimal(10, 2)
  totalCost       Decimal       @db.Decimal(10, 2)
  receivedQty     Decimal       @default(0) @db.Decimal(12, 4)

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// RESTAURANT — TABLES & RESERVATIONS
// ─────────────────────────────────────────────

model RestaurantTable {
  id         String      @id @default(uuid())
  storeId    String
  number     String
  name       String?
  capacity   Int         @default(4)
  status     TableStatus @default(AVAILABLE)
  posX       Float       @default(0)
  posY       Float       @default(0)
  width      Float       @default(100)
  height     Float       @default(100)
  shape      String      @default("rect")
  section    String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  store        Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders       Order[]
  reservations Reservation[]
}

model Reservation {
  id           String      @id @default(uuid())
  storeId      String
  tableId      String?
  customerId   String?
  customerName String
  customerPhone String?
  partySize    Int
  reservedAt   DateTime
  duration     Int         @default(90)
  status       String      @default("confirmed")
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  store        Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  table        RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
}

// ─────────────────────────────────────────────
// BEAUTY / SALON — APPOINTMENTS
// ─────────────────────────────────────────────

model Appointment {
  id           String            @id @default(uuid())
  storeId      String
  customerId   String?
  customerName String
  customerPhone String?
  status       AppointmentStatus @default(PENDING)
  startTime    DateTime
  endTime      DateTime
  notes        String?
  noShowFee    Decimal?          @db.Decimal(10, 2)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  customer     Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  services     AppointmentService[]
}

model AppointmentService {
  id            String   @id @default(uuid())
  appointmentId String
  serviceId     String
  staffId       String?
  duration      Int
  price         Decimal  @db.Decimal(10, 2)

  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service       Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff         Staff?      @relation("ServiceStaff", fields: [staffId], references: [id], onDelete: SetNull)
}

model Commission {
  id         String   @id @default(uuid())
  staffId    String
  orderId    String?
  serviceId  String?
  type       CommissionType
  rate       Decimal  @db.Decimal(10, 2)
  amount     Decimal  @db.Decimal(10, 2)
  isPaid     Boolean  @default(false)
  paidAt     DateTime?
  createdAt  DateTime @default(now())

  staff      Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// REPORTING & PAYROLL
// ─────────────────────────────────────────────

model Report {
  id         String   @id @default(uuid())
  storeId    String
  type       String
  period     String
  startDate  DateTime
  endDate    DateTime
  data       Json
  sentAt     DateTime?
  createdAt  DateTime @default(now())

  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Payroll {
  id           String   @id @default(uuid())
  merchantId   String
  storeId      String
  staffId      String
  periodStart  DateTime
  periodEnd    DateTime
  regularHours Decimal  @db.Decimal(8, 2)
  overtimeHours Decimal @default(0) @db.Decimal(8, 2)
  hourlyWage   Decimal  @db.Decimal(10, 2)
  baseWages    Decimal  @db.Decimal(10, 2)
  tips         Decimal  @default(0) @db.Decimal(10, 2)
  commissions  Decimal  @default(0) @db.Decimal(10, 2)
  deductions   Decimal  @default(0) @db.Decimal(10, 2)
  bonuses      Decimal  @default(0) @db.Decimal(10, 2)
  netPay       Decimal  @db.Decimal(10, 2)
  isPaid       Boolean  @default(false)
  paidAt       DateTime?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─────────────────────────────────────────────
// SYSTEM — AUDIT, SYNC QUEUE
// ─────────────────────────────────────────────

model AuditLog {
  id          String      @id @default(uuid())
  storeId     String
  staffId     String?
  action      AuditAction
  entity      String
  entityId    String?
  before      Json?
  after       Json?
  ipAddress   String?
  deviceId    String?
  createdAt   DateTime    @default(now())

  store       Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  staff       Staff?      @relation(fields: [staffId], references: [id], onDelete: SetNull)
}

model SyncQueue {
  id          String     @id @default(uuid())
  storeId     String
  deviceId    String?
  entity      String
  entityId    String
  action      String
  payload     Json
  status      SyncStatus @default(PENDING)
  retries     Int        @default(0)
  error       String?
  processedAt DateTime?
  createdAt   DateTime   @default(now())

  store       Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
}
