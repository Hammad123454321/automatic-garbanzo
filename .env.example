# ─── Database ─────────────────────────────────────────────────────────────────
# Must match the docker-compose.yml values exactly
DATABASE_URL="postgresql://postgres:password@localhost:5432/pos_platform"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="dev-secret-change-in-production"
JWT_REFRESH_SECRET="dev-refresh-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# ─── Super Admin (used by seed.ts to create the first admin account) ──────────
SUPER_ADMIN_EMAIL="admin@pos.local"
SUPER_ADMIN_PASSWORD="Admin1234!"

# ─── Redis (optional) ─────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Email (optional) ─────────────────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM=""

# ─── AI Features (optional) ───────────────────────────────────────────────────
OPENAI_API_KEY=""

# ─── Payment Terminal - PAX (optional) ────────────────────────────────────────
PAX_API_URL=""
PAX_MERCHANT_ID=""
PAX_TERMINAL_ID=""

# ─── Delivery (optional) ──────────────────────────────────────────────────────
DOORDASH_DEVELOPER_ID=""
DOORDASH_KEY_ID=""
DOORDASH_SIGNING_SECRET=""

# ─── File Upload ──────────────────────────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760
